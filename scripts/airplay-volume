#!/bin/bash
# Called by shairport-sync with AirPlay volume in dB as $1.
# AirPlay range: 0.0 (max) to -30.0 (min); -144.0 = mute.
# Maps linearly to Sonos 0-100.
AIRPLAY_DB="$1"
[ -z "$AIRPLAY_DB" ] && exit 0

# awk instead of python3: this runs on every volume tick and a full
# interpreter start-up is noticeable on slower Pis.
SONOS_VOL=$(awk -v v="$AIRPLAY_DB" 'BEGIN {
    if (v <= -30.0) { print 0; exit }
    vol = int((v + 30) / 30 * 100 + 0.5)
    if (vol < 0) vol = 0
    if (vol > 100) vol = 100
    print vol
}')

curl -s -X POST --max-time 5 "http://localhost:8080/volume/$SONOS_VOL" > /dev/null
