[Unit]
Description=Sonos AirPlay Bridge
After=network-online.target
Wants=network-online.target
Before=shairport-sync.service

[Service]
RuntimeDirectory=sonos-bridge
RuntimeDirectoryMode=0755
ExecStartPre=/usr/bin/mkfifo -m 0666 /run/sonos-bridge/audio
ExecStart=/usr/bin/python3 /opt/sonos-bridge/bridge.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
